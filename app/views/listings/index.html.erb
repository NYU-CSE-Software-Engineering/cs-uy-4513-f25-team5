<p id="notice"><%= notice %></p>
<p id="alert"><%= alert %></p>

<h1>All Listings</h1>

<% if @listings.any? %>
  <% @listings.each do |listing| %>
    <% if listing.image_base64.present? %>
      <img src="data:image/png;base64,<%= listing.image_base64 %>" width="64" height="64">
    <% else %>
      <span>No image</span>
    <% end %>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Price</th>
          <th>City</th>
          <th>Status</th>
          <th colspan="3"></th>
        </tr>
      </thead>
      <tbody>
          <tr>
            <td><%= listing.title %></td>
            <td>$<%= number_with_precision(listing.price, precision: 2) %></td>
            <td><%= listing.city %></td>
            <td><%= listing.status %></td>
            <td><%= link_to 'Show', listing_path(listing) %></td>
            <td><%= link_to 'Edit', edit_listing_path(listing) %></td>
            <td><%= button_to 'Delete', listing_path(listing), method: :delete, data: { confirm: 'Are you sure?' } %></td>
          </tr>
      </tbody>
    </table>
  <% end %>
<% else %>
  <p>No listings found.</p>
<% end %>

<br>

<%= link_to 'Create New Listing', new_listing_path %>